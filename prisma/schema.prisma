generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  firstName    String   @db.VarChar(50)
  lastName     String   @db.VarChar(50)
  email        String   @unique @db.VarChar(255)
  passwordHash String   @db.VarChar(255)
  roleId       String   @db.Uuid
  isActive     Boolean  @default(true)
  isVerified   Boolean  @default(false)
  deletedAt    DateTime? @db.Timestamptz(6)
  createdAt    DateTime @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @db.Timestamptz(6)

  // Relationships
  role         Role     @relation(fields: [roleId], references: [id])
  addresses    Address[]
  phoneNumbers PhoneNumber[]
  stockMovements StockMovement[]
  auditLogs AuditLog[]

  @@index([roleId])
  @@index([deletedAt])
  @@map("users")
  productReviews ProductReview[]
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(50)
  description String?  @db.VarChar(255)
  permissions Json?
  deletedAt   DateTime? @db.Timestamptz(6)
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @db.Timestamptz(6)

  // Relationships
  users User[]

  @@index([deletedAt])
  @@map("roles")
}

model Address {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @db.Uuid
  houseNo      String  @db.VarChar(20)
  addressLine1 String   @db.VarChar(255)
  addressLine2 String?  @db.VarChar(255)
  city         String   @db.VarChar(100)
  province     String   @db.VarChar(100)
  zipcode      String   @db.VarChar(20)
  country      String   @db.VarChar(100) @default("Sri Lanka")
  type         AddressType  @default(DELIVERY)
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @db.Timestamptz(6)

  // Relationship
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("addresses")
}

model PhoneNumber {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @db.Uuid
  phoneNumber String    @db.VarChar(20)
  countryCode String?   @db.VarChar(5) @default("+94")
  type   PhoneType @default(MOBILE)
  isDefault   Boolean   @default(false)
  isVerified  Boolean   @default(false)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(6)

  // Relationship
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([phoneNumber])
  @@map("phone_numbers")
}

model Category {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(100)
  slug        String   @unique @db.VarChar(100)
  description String?  @db.Text
  sizeGuide   String?  @db.VarChar(500)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  deletedAt   DateTime? @db.Timestamptz(6)
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @db.Timestamptz(6)

  // Relationships
  products Product[]

  @@index([deletedAt])
  @@map("categories")
}

model Design {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(100)
  slug        String   @unique @db.VarChar(100)
  description String?  @db.Text
  isActive    Boolean  @default(true)
  deletedAt   DateTime? @db.Timestamptz(6)
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @db.Timestamptz(6)

  // Relationships
  productDesigns ProductDesign[]

  @@index([deletedAt])
  @@map("designs")
}


model Color {
  id             String    @id @default(uuid()) @db.Uuid
  name           String    @unique @db.VarChar(50)
  hexCode        String?   @db.Char(6)
  swatchImageUrl String?   @db.VarChar(500)
  isActive       Boolean   @default(true)
  deletedAt      DateTime? @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @db.Timestamptz(6)

  // Relationships
  variants      ProductVariant[]
  productImages ProductImage[]

  @@index([deletedAt])
  @@map("colors")
}

model Size {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @unique @db.VarChar(10) // 'XS', 'S', 'M', 'L', 'XL', 'XXL', etc.
  description String?   @db.VarChar(50) // 'Extra Small', 'Small', 'Medium', etc.
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  deletedAt   DateTime? @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(6)

  // Relationships
  variants ProductVariant[]

  @@index([deletedAt])
  @@map("sizes")
}

model Product {
  id                 String        @id @default(uuid()) @db.Uuid
  name               String        @db.VarChar(200)
  slug               String        @unique @db.VarChar(200)
  description        String?       @db.Text
  categoryId         String        @db.Uuid
  sizeGuide          String?       @db.VarChar(500) // overrides Category.sizeGuide when set
  gender             GenderTarget  @default(UNISEX)
  ageGroup           AgeGroup      @default(ADULT)
  brand              String?       @db.VarChar(100) @default("Wichithra")
  material           String?       @db.VarChar(200)
  careInstructions   String?       @db.Text
  discountPercentage Decimal       @db.Decimal(5, 2) @default(0) // display-only, for strikethrough pricing
  isFeatured         Boolean       @default(false)
  isActive           Boolean       @default(true)
  status             ProductStatus @default(DRAFT)
  metaTitle          String?       @db.VarChar(200)
  metaDescription    String?       @db.Text
  deletedAt          DateTime?     @db.Timestamptz(6)
  createdAt          DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt          DateTime      @updatedAt @db.Timestamptz(6)

  // Relationships
  category       Category         @relation(fields: [categoryId], references: [id])
  variants       ProductVariant[]
  productDesigns ProductDesign[]
  productImages  ProductImage[]
  productTags    ProductTag[]
  productReviews ProductReview[]

  @@index([categoryId])
  @@index([isActive])
  @@index([isFeatured])
  @@index([deletedAt])
  @@index([gender])
  @@index([ageGroup])
  @@map("products")
}

model ProductVariant {
  id           String    @id @default(uuid()) @db.Uuid
  productId    String    @db.Uuid
  colorId      String    @db.Uuid
  sizeId       String    @db.Uuid
  sku          String    @unique @db.VarChar(100)
  costPrice    Decimal?  @db.Decimal(10, 2)
  sellingPrice Decimal   @db.Decimal(10, 2)
  isMainColor  Boolean   @default(false) // marks the default color shown on the product listing page
  isActive     Boolean   @default(true)
  deletedAt    DateTime? @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @db.Timestamptz(6)

  // Relationships
  product   Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  color     Color      @relation(fields: [colorId], references: [id])
  size      Size       @relation(fields: [sizeId], references: [id])
  inventory Inventory?

  @@unique([productId, colorId, sizeId])
  @@index([productId])
  @@index([deletedAt])
  @@map("product_variants")
}

model ProductDesign {
  id        String   @id @default(uuid()) @db.Uuid
  productId String   @db.Uuid
  designId  String   @db.Uuid
  deletedAt DateTime? @db.Timestamptz(6)
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  // Relationships
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  design  Design  @relation(fields: [designId], references: [id], onDelete: Cascade)

  @@unique([productId, designId])
  @@index([deletedAt])
  @@map("product_designs")
}


model ProductImage {
  id        String   @id @default(uuid()) @db.Uuid
  productId String   @db.Uuid
  colorId   String?  @db.Uuid
  imageUrl  String   @db.VarChar(500)
  altText   String?  @db.VarChar(200)
  isPrimary Boolean  @default(false)
  sortOrder Int      @default(0)
  deletedAt DateTime? @db.Timestamptz(6)
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  // Relationships
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  color   Color?  @relation(fields: [colorId], references: [id])

  @@index([productId])
  @@index([deletedAt])
  @@map("product_images")
}

model ProductReview {
  id                String   @id @default(uuid()) @db.Uuid
  productId         String   @db.Uuid
  userId            String   @db.Uuid
  rating            Int      // 1–5
  title             String?  @db.VarChar(200)
  body              String?  @db.Text
  isVerifiedPurchase Boolean @default(false)
  isApproved        Boolean  @default(false)
  helpfulCount      Int      @default(0)
  createdAt         DateTime @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime @updatedAt @db.Timestamptz(6)

  // Relationships
  product      Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id])
  reviewImages ReviewImage[]

  @@unique([productId, userId])  // one review per user per product
  @@index([productId])
  @@index([isApproved])
  @@map("product_reviews")
}

model ReviewImage {
  id        String   @id @default(uuid()) @db.Uuid
  reviewId  String   @db.Uuid
  imageUrl  String   @db.VarChar(500)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  // Relationships
  review ProductReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@map("review_images")
}

model Inventory {
  id                String    @id @default(uuid()) @db.Uuid
  variantId         String    @unique @db.Uuid
  quantity          Int       @default(0)
  reservedQuantity  Int       @default(0)
  lowStockThreshold Int?      @default(5)
  deletedAt         DateTime? @db.Timestamptz(6)
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @db.Timestamptz(6)

  // Relationships
  variant        ProductVariant  @relation(fields: [variantId], references: [id])
  stockMovements StockMovement[]

  @@index([quantity, lowStockThreshold])
  @@index([deletedAt])
  @@map("inventory")
}

model StockMovement {
  id           String              @id @default(uuid()) @db.Uuid
  inventoryId  String              @db.Uuid
  movementType StockMovementType
  quantity     Int                 @default(0)
  reason       String?             @db.VarChar(500)
  referenceId  String?             @db.Uuid //for billing references
  notes        String?             @db.Text
  createdBy    String?             @db.Uuid
  createdAt    DateTime            @default(now()) @db.Timestamptz(6)

  // Relationships
  inventory    Inventory @relation(fields: [inventoryId], references: [id])
  createdByUser User?   @relation(fields: [createdBy], references: [id])

  @@index([inventoryId])
  @@map("stock_movements")
}

model Tag {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique @db.VarChar(50)
  slug      String   @unique @db.VarChar(50)
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  // Relationships
  productTags ProductTag[]

  @@map("tags")
}

model ProductTag {
  id        String   @id @default(uuid()) @db.Uuid
  productId String   @db.Uuid
  tagId     String   @db.Uuid
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  // Relationships
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([productId, tagId])
  @@map("product_tags")
}

model AuditLog {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @db.Uuid
  action        String   @db.VarChar(100) // "CREATE", "UPDATE", "DELETE", "LOGIN"
  entity        String   @db.VarChar(100) // "Product", "Order", "User"
  entityId      String?  @db.Uuid
  oldValues     Json?
  newValues     Json?
  description   String?  @db.VarChar(500)
  ipAddress     String?  @db.VarChar(45)  // IPv6 max length
  createdAt     DateTime @default(now()) @db.Timestamptz(6)

  // Relationships
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([entity, entityId])
  @@map("audit_logs")
}

//ENUMS
enum PhoneType {
  MOBILE
  HOME

  @@map("phone_type")
}

enum AddressType {
  DELIVERY
  BILLING

  @@map("address_type")
}

enum ProductStatus {
  DRAFT // not ready for customers/seasonal products/under review
  DISCONTINUED // end of line products
  OUTOFSTOCK //out of stock
  AVAILABLE // ready to show to customers

  @@map("product_status")
}

enum StockMovementType {
  IN // new inventory in, return from customers (ex: 100 units of blue t-shirts size M received from your manufacturer)
  OUT // sold to customers, returned to supply(defectives)
  ADJUSTMENT // stock count corrections, damaged items
  RESERVED // items in customers shopping cart, orders placed but not yet shipped, wholesale orders
  //Example: Customer adds 2 black t-shirts to cart, those items get reserved for 30 minutes.
  RELEASED //reserved item freed up(cart expires or removes items), cancelled orders returnign inventory
  // Customer's cart expired, so the 2 reserved black t-shirts are released back to available stock.
  @@map("stock_movement_type")
}

enum GenderTarget {
  MALE
  FEMALE
  UNISEX
  BOYS
  GIRLS
  KIDS

  @@map("gender_target")
}

enum AgeGroup {
  INFANT
  TODDLER
  KIDS
  TEEN
  ADULT

  @@map("age_group")
}